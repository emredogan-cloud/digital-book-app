# ── Dependencies ──
node_modules/

# ── Native (Capacitor) — android/ is committed from SUB-PR 1.1+; Capacitor's android/.gitignore handles internal build artifacts. iOS deferred to Phase 8.
/ios/

# ── Build output / artifacts ──
dist/
build/
www/shell/                 # Vite-built shell bundle — regenerated by `npm run build` / `npm run cap:sync`
*.log
*.tmp

# ── Capacitor / Android signing (NEVER commit keystores) ──
.gradle/
*.apk
*.aab
*.keystore
*.jks

# ── Environment / secrets ──
.env
.env.*
!.env.example

# ── Editor / OS ──
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Claude Code personal (local) settings — shared settings.json stays tracked ──
.claude/settings.local.json
