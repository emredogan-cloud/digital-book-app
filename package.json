{
  "name": "living-library",
  "version": "0.0.0",
  "private": true,
  "description": "Living Library — premium, offline-first mobile reading catalog (Capacitor WebView hybrid). Android-first.",
  "license": "UNLICENSED",
  "scripts": {
    "serve": "python3 -m http.server 8080 --bind 127.0.0.1 --directory www",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src-shell",
    "format": "prettier --write \"src-shell/**/*.{ts,js,json}\"",
    "test": "tsx test/storage-migration.test.ts",
    "cap:sync": "vite build && cap sync",
    "cap:doctor": "cap doctor",
    "prod": "vite build && cap sync && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@sentry/browser": "^10.54.0",
    "posthog-js": "^1.376.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  }
}
